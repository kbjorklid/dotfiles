[alias]
    uncommit = reset --soft HEAD^
    co = checkout
    cob = checkout -b
    st = status
    ls = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)' --all
[push]
    default = matching
[include]
    path = ~/.dotfiles/gitconfig.local
[core]
    editor = nvim

