snippet render "Simple render method"
render$1($2) {
	return (
		$0
	);
}
endsnippet

snippet constructor-react "Constructor of React component"
constructor(props) {
	super(props);
	$0
}
endsnippet

snippet bind-react "Bind method"
this.$1 = this.$1.bind(this);
endsnippet


# LODASH
snippet "_.forEach" "_.forEach"
_.forEach(${1:collection}, function (${2:val}${4/\w/, /}${4:i}) {
	$0
});
endsnippet

# NODE / IO
snippet require "var thing = require('thing')"
var $1 = require('${0:$1}');
endsnippet

snippet "^\s*require" "var x = require('x')" r
var $1 = require('${0:$1}');
endsnippet

snippet "^(\s*var\s)([^\s]+)(\s*=\s*)require" "require('x')" r
`!p
snip.rv = match.group(1) + match.group(2) + match.group(3) + "require('"
`${0:`!p
varname = match.group(2)
snip.rv = varname[:1].lower() + varname[1:]
`}');
endsnippet

snippet bookshelf_model "Bookshelf Model with Registry"
var bookshelf = require('$1');
var BaseModel = ${2:'bookshelf.Model'};

var ${3:Model} = BaseModel.extend({
	tableName: '${4:`!p
s1 = re.sub('(.)([A-Z][a-z]+)', r'\1_\2', t[3])
snip.rv = re.sub('([a-z0-9])([A-Z])', r'\1_\2', s1).lower();
`}'

module.exports = bookshelf.model('$3', $3);
});
endsnippet
