
snippet function "JS function" w
function $1($2) {
	$0
}
endsnippet

snippet fun "JS function" w
function $1($2) {
	$0
}
endsnippet

snippet pfun "JS Object method"
${1:property} : function ($2) {
	$0
}
endsnippet

snippet consoleLog "console.log(..." w
console.log('$1');
endsnippet

snippet consoleWarn "console.warn(..." w
console.warn('$1');
endsnippet

snippet clog "console.log(..." w
console.log('$1');
endsnippet

snippet then ".then(function (..." w
then(function ($1) {
	$2
})
endsnippet

snippet self "var self = this;"
var self = this;
endsnippet

snippet returnf "return false;"
return false;
endsnippet

snippet returnt "return true;"
return true;
endsnippet

#== QUnit
snippet test "QUnit: test(...)" b
test('$1', function (assert) {
	$0
});
endsnippet

#== EMBER

snippet getToVar "var item = this.get('item');"
var $1 = ${2:this}.get('${0:$1}');
endsnippet

snippet import "import ... from ..." !
import $1 from '${0:`!p
if t[1] == "DS":
    snip.rv='ember-data'
elif t[1] == "Ember":
    snip.rv='ember'
`}';
endsnippet

snippet EmComputed "Ember.computed(..."
${1:property} : Ember.computed(
	'$2',
	'$3',
	function (key, value) {
		return $0;
	}
)
endsnippet

snippet EmIsEmpty "Ember.isEmpty(..." w
Ember.isEmpty($0)
endsnippet

snippet EmRoute "export default Ember.Route..."
export default Ember.Route.extend({
	$0
});
endsnippet

snippet EmActions "Ember actions definition"
actions : {
	${1:name} : function () {
		$0
	}
}
endsnippet

